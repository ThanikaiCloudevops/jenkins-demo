pipeline {
    agent none

    stages {
        stage('Build and Test Matrix') {
            matrix {

                axes {
                    axis {
                        name 'OS'
                        values 'Linux', 'Mac'
                    }
                    axis {
                        name 'Mobile'
                        values 'Android', 'IOS'
                    }
                }

                agent any

                stages {

                    stage('Build') {
                        steps {
                            echo "Building on ${OS}"
                        }
                    }

                    stage('Test') {
                        steps {
                            echo "Running ${Mobile} tests on ${OS}"
                        }
                    }
                }
            }
        }
    }
}
